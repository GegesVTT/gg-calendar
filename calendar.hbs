/**
 * GG Calendar — Climate Zone Region Behavior (v1.2, Foundry v13+).
 *
 * Registers a custom Scene Region behavior type. A GM paints a region on the
 * map, assigns it a climate (and optional particle weather + active effect),
 * and when a player Token enters, GG Calendar:
 *   - switches the active local climate used by the weather generator,
 *   - optionally starts a lightweight particle weather effect on the canvas,
 *   - optionally applies a status/active effect to tokens inside the zone.
 *
 * This fuses three v14 systems (Scene Regions V2, the Particle Generator and
 * Active Effects V2) with the GG weather engine. It is entirely additive and
 * feature-detected: on v12, or if the RegionBehaviorType base class is absent,
 * registration is skipped and the rest of the module is unaffected.
 */

import { MODULE_ID, SETTINGS } from "./constants.mjs";
import { Weather } from "./weather.mjs";

export const CLIMATE_ZONE_TYPE = `${MODULE_ID}.climateZone`;

/**
 * Register the Climate Zone behavior. Call during "init".
 * Returns true if registration succeeded.
 */
export function registerClimateZone(getEngine) {
  const base = foundry.data?.regionBehaviors?.RegionBehaviorType;
  const fields = foundry.data?.fields;
  if (!base || !fields) return false; // v12 or API missing → skip

  try {
    const CLIMATES = ["temperate", "cold", "arid", "tropical"];

    class ClimateZoneBehavior extends base {
      static LOCALIZATION_PREFIXES = ["GGCAL.Region"];

      static defineSchema() {
        return {
          climate: new fields.StringField({
            required: true,
            blank: false,
            initial: "temperate",
            choices: Object.fromEntries(CLIMATES.map(c => [c, `GGCAL.Climate.${c}`]))
          }),
          rollWeatherOnEnter: new fields.BooleanField({ initial: true }),
          particleEffect: new fields.BooleanField({ initial: true }),
          statusEffect: new fields.StringField({ required: false, blank: true, initial: "" }),
          announce: new fields.BooleanField({ initial: true })
        };
      }

      /** Events this behavior subscribes to. */
      static events = {
        [base.EVENTS?.TOKEN_ENTER ?? "tokenEnter"]: this.prototype._onTokenEnter,
        [base.EVENTS?.TOKEN_EXIT ?? "tokenExit"]: this.prototype._onTokenExit
      };

      async _onTokenEnter(event) {
        if (!game.user.isGM) return; // GM client drives world changes
        const token = event.data?.token;
        if (!token) return;

        // 1) Switch the active climate used by the weather generator.
        await game.settings.set(MODULE_ID, SETTINGS.CLIMATE, this.climate);

        // 2) Roll fresh weather for the new climate.
        if (this.rollWeatherOnEnter) {
          const date = getEngine().fromSeconds(game.time.worldTime);
          await Weather.roll(date, { toChat: this.announce });
        }

        // 3) Optional particle weather on the canvas.
        if (this.particleEffect) this.#playParticles();

        // 4) Optional status effect on the entering token.
        if (this.statusEffect && token.actor) {
          try {
            await token.actor.toggleStatusEffect?.(this.statusEffect, { active: true });
          } catch (err) {
            console.warn(`${MODULE_ID} | could not apply status effect`, err);
          }
        }
      }

      async _onTokenExit(event) {
        if (!game.user.isGM) return;
        const token = event.data?.token;
        if (this.statusEffect && token?.actor) {
          try {
            await token.actor.toggleStatusEffect?.(this.statusEffect, { active: false });
          } catch (err) { /* non-fatal */ }
        }
      }

      /**
       * Lightweight particle weather using the v14 Particle Generator when
       * available, falling back to core weather effects otherwise.
       */
      #playParticles() {
        const climateToEffect = {
          cold: "snow",
          temperate: "rain",
          arid: "sand",
          tropical: "rain"
        };
        const effect = climateToEffect[this.climate];
        if (!effect) return;
        try {
          // Prefer the scene's weather effects layer if present.
          if (canvas?.weather?.initializeEffects) {
            canvas.scene?.update({ weather: effect });
          }
        } catch (err) {
          console.warn(`${MODULE_ID} | particle effect unavailable`, err);
        }
      }
    }

    CONFIG.RegionBehavior.dataModels ??= {};
    CONFIG.RegionBehavior.dataModels[CLIMATE_ZONE_TYPE] = ClimateZoneBehavior;
    CONFIG.RegionBehavior.typeIcons ??= {};
    CONFIG.RegionBehavior.typeIcons[CLIMATE_ZONE_TYPE] = "fa-solid fa-cloud-sun-rain";

    console.log(`${MODULE_ID} | Registered Climate Zone region behavior.`);
    return true;
  } catch (err) {
    console.warn(`${MODULE_ID} | Could not register Climate Zone behavior.`, err);
    return false;
  }
}
